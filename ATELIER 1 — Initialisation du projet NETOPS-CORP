Étape 3 — Pipeline CI/CD GitLab
# .gitlab-ci.yml
stages:
  - lint
  - syntax_check
  - test_lab
  - deploy_staging
  - validate_staging
  - deploy_production

variables:
  ANSIBLE_FORCE_COLOR: "true"
  ANSIBLE_HOST_KEY_CHECKING: "False"

lint_yaml:
  stage: lint
  image: pipelinecomponents/ansible-lint:latest
  script:
    - yamllint -c .yamllint.yml playbooks/ group_vars/ inventories/
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'

lint_ansible:
  stage: lint
  image: pipelinecomponents/ansible-lint:latest
  script:
    - ansible-lint playbooks/
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'

syntax_check:
  stage: syntax_check
  script:
    - source ~/.venv/netops/bin/activate
    - ansible-playbook playbooks/deploy/site.yml \
        --syntax-check -i inventories/staging/

test_lab:
  stage: test_lab
  script:
    - docker compose -f tests/lab/docker-compose.yml up -d
    - sleep 20
    - ansible-playbook playbooks/deploy/site.yml \
        -i tests/lab/inventory.yml --check
    - docker compose -f tests/lab/docker-compose.yml down

deploy_staging:
  stage: deploy_staging
  script:
    - ansible-playbook playbooks/deploy/site.yml \
        -i inventories/staging/ \
        --vault-password-file .vault_pass
  environment: staging
  rules:
    - if: '$CI_COMMIT_BRANCH == "staging"'

validate_staging:
  stage: validate_staging
  script:
    - pytest tests/post_checks/ -v \
        --html=reports/staging_report.html
  artifacts:
    paths: [reports/]
  rules:
    - if: '$CI_COMMIT_BRANCH == "staging"'

deploy_production:
  stage: deploy_production
  script:
    - ansible-playbook playbooks/deploy/site.yml \
        -i inventories/production/ \
        --vault-password-file .vault_pass
  environment: production
  when: manual
  rules:
    - if: '$CI_COMMIT_BRANCH == "main"'

