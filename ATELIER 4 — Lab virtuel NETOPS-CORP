Étape 3 — Validation de la topologie
# Vérifier les sessions BGP
echo "=== BGP Summary — Paris ==="
docker exec netops-frr-paris vtysh -c "show bgp summary"
# Expected : dc1 (10.0.12.2) et dc2 (10.0.12.3) en état "Established"

echo "=== Routes BGP reçues ==="
docker exec netops-frr-paris vtysh -c "show bgp ipv4 unicast"
# Expected : routes 10.1.0.0/16 (DC1) et 10.2.0.0/16 (DC2) présentes

echo "=== Connectivité end-to-end ==="
docker exec netops-frr-paris ping -c 3 10.0.12.2
docker exec netops-frr-paris ping -c 3 10.0.12.3

# Inventaire Ansible pour le lab
cat > tests/lab/inventory.yml << 'EOF'
all:
  hosts:
    lab-paris:
      ansible_host: 172.20.0.11
      site: paris
      role: core_router
    lab-dc1:
      ansible_host: 172.20.0.12
      site: dc1-lyon
      role: border_leaf
    lab-dc2:
      ansible_host: 172.20.0.13
      site: dc2-marseille
      role: border_leaf
    lab-bordeaux:
      ansible_host: 172.20.0.21
      site: bordeaux
      role: vedge
  vars:
    ansible_user: frr
    ansible_connection: network_cli
    ansible_network_os: frr
EOF

# Test Ansible sur le lab
ansible -i tests/lab/inventory.yml all -m ping

