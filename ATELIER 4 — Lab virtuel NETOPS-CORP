🛠 ATELIER 4 — Lab virtuel NETOPS-CORP

Outils utilisés : Docker, Docker Compose, FRRouting, Batfish
Objectif : Démarrer le lab complet et valider la topologie BGP NETOPS-CORP

************************************************************************************************************************
Étape 1 — Docker Compose du lab

# docker-compose.yml
version: '3.9'

services:
  # ── Toolbox Ansible/Python ─────────────────────────
  toolbox:
    build: .
    container_name: netops-toolbox
    volumes:
      - ./:/workspace
      - ~/.ssh:/root/.ssh:ro
    environment:
      - ANSIBLE_HOST_KEY_CHECKING=False
      - NET_USER=frr
      - NET_PASS=frr
    networks:
      mgmt:
        ipv4_address: 172.20.0.100

  # ── Routeurs FRR (simulent l'infra NETOPS-CORP) ────
  frr-paris:
    image: frrouting/frr:latest
    container_name: netops-frr-paris
    privileged: true
    hostname: paris-rtr-01
    networks:
      mgmt: {ipv4_address: 172.20.0.11}
      wan:  {ipv4_address: 10.0.12.1}

  frr-dc1:
    image: frrouting/frr:latest
    container_name: netops-frr-dc1
    privileged: true
    hostname: dc1-border-01
    networks:
      mgmt: {ipv4_address: 172.20.0.12}
      wan:  {ipv4_address: 10.0.12.2}

  frr-dc2:
    image: frrouting/frr:latest
    container_name: netops-frr-dc2
    privileged: true
    hostname: dc2-border-01
    networks:
      mgmt: {ipv4_address: 172.20.0.13}
      wan:  {ipv4_address: 10.0.12.3}

  frr-bordeaux:
    image: frrouting/frr:latest
    container_name: netops-frr-bordeaux
    privileged: true
    hostname: branch-bordeaux-vedge
    networks:
      mgmt:    {ipv4_address: 172.20.0.21}
      sdwan:   {ipv4_address: 10.20.1.1}

  # ── Batfish (analyse statique) ─────────────────────
  batfish:
    image: batfish/allinone:latest
    container_name: netops-batfish
    ports: ["9997:9997", "9996:9996"]
    networks:
      mgmt: {ipv4_address: 172.20.0.200}

  # ── Monitoring ─────────────────────────────────────
  prometheus:
    image: prom/prometheus:latest
    container_name: netops-prometheus
    volumes:
      - ./monitoring/prometheus.yml:/etc/prometheus/prometheus.yml
    ports: ["9090:9090"]
    networks:
      mgmt: {ipv4_address: 172.20.0.201}

  grafana:
    image: grafana/grafana:latest
    container_name: netops-grafana
    ports: ["3001:3000"]
    environment:
      - GF_SECURITY_ADMIN_PASSWORD=netops123
    networks:
      mgmt: {ipv4_address: 172.20.0.202}

networks:
  mgmt:
    driver: bridge
    ipam: {config: [{subnet: "172.20.0.0/24"}]}
  wan:
    driver: bridge
    ipam: {config: [{subnet: "10.0.12.0/28"}]}
  sdwan:
    driver: bridge
    ipam: {config: [{subnet: "10.20.0.0/16"}]}

