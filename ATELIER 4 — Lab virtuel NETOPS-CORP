Étape 2 — Démarrage et configuration BGP
# Démarrer le lab
docker compose up -d
docker compose ps   # Vérifier que tous sont "Up"

# Configurer BGP sur Paris HQ
docker exec netops-frr-paris vtysh << 'EOF'
configure terminal
hostname paris-rtr-01
!
router bgp 65001
  bgp router-id 10.0.12.1
  bgp log-neighbor-changes
  neighbor 10.0.12.2 remote-as 65002
  neighbor 10.0.12.2 description DC1-Lyon
  neighbor 10.0.12.3 remote-as 65003
  neighbor 10.0.12.3 description DC2-Marseille
  !
  address-family ipv4 unicast
    network 10.0.1.0/24
    neighbor 10.0.12.2 activate
    neighbor 10.0.12.3 activate
  exit-address-family
end
write memory
EOF

# Configurer BGP sur DC1
docker exec netops-frr-dc1 vtysh << 'EOF'
configure terminal
hostname dc1-border-01
router bgp 65002
  bgp router-id 10.0.12.2
  neighbor 10.0.12.1 remote-as 65001
  neighbor 10.0.12.1 description Paris-HQ
  address-family ipv4 unicast
    network 10.1.0.0/16
    neighbor 10.0.12.1 activate
  exit-address-family
end
write memory
EOF

# Configurer BGP sur DC2
docker exec netops-frr-dc2 vtysh << 'EOF'
configure terminal
hostname dc2-border-01
router bgp 65003
  bgp router-id 10.0.12.3
  neighbor 10.0.12.1 remote-as 65001
  neighbor 10.0.12.1 description Paris-HQ
  address-family ipv4 unicast
    network 10.2.0.0/16
    neighbor 10.0.12.1 activate
  exit-address-family
end
write memory
EOF

