# netops_corp/devices/base.py
from abc import ABC, abstractmethod
from dataclasses import dataclass
from typing import Optional
import logging

@dataclass
class DeviceCredentials:
    hostname: str
    username: str
    password: str
    enable_password: Optional[str] = None
    port: int = 22
    timeout: int = 30
    site: str = "unknown"
    role: str = "unknown"

class NetworkDevice(ABC):
    """
    Classe abstraite représentant un équipement réseau NETOPS-CORP.
    
    Pourquoi abstraite ?
    - Garantir que TOUS les équipements exposent la même interface
    - Permettre au code métier de ne pas savoir si c'est IOS, NX-OS, ou FRR
    - Faciliter les tests (on peut mocker cette classe)
    """
    def __init__(self, creds: DeviceCredentials):
        self.creds = creds
        self.logger = logging.getLogger(
            f"{self.__class__.__name__}[{creds.hostname}]"
        )
        self._conn = None

    @abstractmethod
    def connect(self) -> bool:
        """Établit la connexion. Lève une exception si impossible."""
        pass

    @abstractmethod
    def disconnect(self) -> None:
        pass

    @abstractmethod
    def get_interfaces(self) -> list[dict]:
        """
        Retourne les interfaces sous forme standardisée :
        [{"name": "Gi0/0", "status": "connected", "speed": 1000}, ...]
        """
        pass

    @abstractmethod
    def get_bgp_summary(self) -> list[dict]:
        pass

    @abstractmethod
    def push_config(self, config: str) -> bool:
        pass

    @abstractmethod
    def save_config(self) -> bool:
        pass

    # Context manager : permet d'utiliser "with CiscoIOS(...) as dev:"
    def __enter__(self):
        self.connect()
        return self

    def __exit__(self, exc_type, exc_val, exc_tb):
        self.disconnect()
        # Ne pas supprimer l'exception si elle existe
        return False

