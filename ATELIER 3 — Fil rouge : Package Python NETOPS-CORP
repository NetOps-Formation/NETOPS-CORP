# netops_corp/utils/logger.py
import logging
import sys
from logging.handlers import RotatingFileHandler
from pathlib import Path

def setup_logger(name: str, level: str = "INFO") -> logging.Logger:
    """
    Logger configuré pour la production NETOPS-CORP :
    - Console : WARNING et au-dessus (pour ne pas noyer l'opérateur)
    - Fichier  : INFO et au-dessus avec rotation (10 Mo, 5 fichiers)
    """
    Path("logs").mkdir(exist_ok=True)
    logger = logging.getLogger(name)
    logger.setLevel(logging.DEBUG)   # Capturer tout au niveau du logger

    fmt = logging.Formatter(
        '%(asctime)s | %(name)-35s | %(levelname)-8s | %(message)s',
        datefmt='%Y-%m-%d %H:%M:%S'
    )

    # Console : WARNING+
    ch = logging.StreamHandler(sys.stdout)
    ch.setLevel(logging.WARNING)
    ch.setFormatter(fmt)

    # Fichier : INFO+ avec rotation
    fh = RotatingFileHandler(
        'logs/netops_corp.log',
        maxBytes=10*1024*1024,
        backupCount=5
    )
    fh.setLevel(logging.INFO)
    fh.setFormatter(fmt)

    logger.addHandler(ch)
    logger.addHandler(fh)
    return logger

