# netops_corp/devices/cisco_ios.py
from netmiko import (ConnectHandler,
                     NetmikoTimeoutException,
                     NetmikoAuthenticationException)
from .base import NetworkDevice, DeviceCredentials
import time

class CiscoIOS(NetworkDevice):
    """
    Implémentation pour les équipements Cisco IOS/IOS-XE.
    Utilisé pour : Paris HQ, branches SD-WAN NETOPS-CORP
    """

    MAX_RETRIES = 3
    RETRY_DELAY = 5

    def connect(self) -> bool:
        for attempt in range(self.MAX_RETRIES):
            try:
                self._conn = ConnectHandler(
                    device_type='cisco_ios',
                    host=self.creds.hostname,
                    username=self.creds.username,
                    password=self.creds.password,
                    secret=self.creds.enable_password or self.creds.password,
                    port=self.creds.port,
                    timeout=self.creds.timeout
                )
                self._conn.enable()
                self.logger.info(
                    f"Connecté ({self.creds.site}/{self.creds.role})"
                )
                return True
            except NetmikoAuthenticationException:
                # Pas de retry sur une erreur d'authentification
                self.logger.error("Échec authentification — vérifier les credentials")
                raise
            except NetmikoTimeoutException:
                if attempt < self.MAX_RETRIES - 1:
                    wait = self.RETRY_DELAY * (attempt + 1)
                    self.logger.warning(
                        f"Timeout (tentative {attempt+1}/{self.MAX_RETRIES})"
                        f" — retry dans {wait}s"
                    )
                    time.sleep(wait)
                else:
                    self.logger.error(f"Timeout après {self.MAX_RETRIES} tentatives")
                    raise

    def disconnect(self) -> None:
        if self._conn:
            self._conn.disconnect()
            self.logger.info("Déconnecté")

    def get_interfaces(self) -> list[dict]:
        """Utilise TextFSM pour parser la sortie en structure Python."""
        raw = self._conn.send_command(
            'show interfaces status', use_textfsm=True
        )
        return raw if isinstance(raw, list) else []

    def get_bgp_summary(self) -> list[dict]:
        raw = self._conn.send_command(
            'show bgp summary', use_textfsm=True
        )
        return raw if isinstance(raw, list) else []

    def push_config(self, config: str) -> bool:
        commands = [l for l in config.splitlines() if l.strip()]
        output = self._conn.send_config_set(commands)
        self.logger.info(f"Config appliquée ({len(commands)} commandes)")
        return True

    def save_config(self) -> bool:
        self._conn.save_config()
        self.logger.info("Config sauvegardée en NVRAM")
        return True

