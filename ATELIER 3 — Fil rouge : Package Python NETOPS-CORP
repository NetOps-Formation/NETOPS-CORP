#!/usr/bin/env python3
# scripts/inventory/collect_state.py
"""
Collecte l'état de tous les équipements NETOPS-CORP
Usage : python3 scripts/inventory/collect_state.py
"""
import yaml, json, os
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime
from rich.console import Console
from rich.table import Table
from rich.progress import Progress
from netops_corp.devices.cisco_ios import CiscoIOS
from netops_corp.devices.base import DeviceCredentials
from netops_corp.utils.logger import setup_logger

logger = setup_logger("collect_state")
console = Console()

def load_hosts_from_inventory(path: str) -> list[dict]:
    """Extrait les hosts de l'inventaire Ansible."""
    with open(path) as f:
        inv = yaml.safe_load(f)

    hosts = []
    def walk(node):
        if "hosts" in node:
            for name, hvars in node["hosts"].items():
                hosts.append({
                    "hostname": name,
                    "host":     hvars.get("ansible_host", name),
                    "site":     hvars.get("site", "unknown"),
                    "role":     hvars.get("role", "unknown"),
                    "os":       hvars.get("ansible_network_os", "cisco.ios.ios"),
                })
        if "children" in node:
            for child in node["children"].values():
                walk(child)

    walk(inv["all"])
    return hosts

def collect_one_device(device: dict) -> dict:
    """Collecte l'état d'un seul équipement. Ne lève jamais d'exception."""
    result = {
        "hostname":        device["hostname"],
        "site":            device["site"],
        "role":            device["role"],
        "status":          "unknown",
        "interfaces_up":   0,
        "interfaces_down": 0,
        "bgp_peers_up":    0,
        "bgp_peers_down":  0,
        "error":           None,
    }
    try:
        creds = DeviceCredentials(
            hostname=device["host"],
            username=os.environ.get("NET_USER", "devnetuser"),
            password=os.environ.get("NET_PASS", "Cisco123!"),
            enable_password=os.environ.get("NET_ENABLE", "Cisco123!"),
            site=device["site"],
            role=device["role"],
            timeout=20
        )
        with CiscoIOS(creds) as dev:
            ifaces = dev.get_interfaces()
            if isinstance(ifaces, list):
                result["interfaces_up"] = sum(
                    1 for i in ifaces if i.get("status") == "connected"
                )
                result["interfaces_down"] = sum(
                    1 for i in ifaces if i.get("status") != "connected"
                )
            bgp = dev.get_bgp_summary()
            if isinstance(bgp, list):
                result["bgp_peers_up"] = sum(
                    1 for p in bgp
                    if str(p.get("state_pfxrcd","")).isdigit()
                )
                result["bgp_peers_down"] = sum(
                    1 for p in bgp
                    if not str(p.get("state_pfxrcd","")).isdigit()
                )
            result["status"] = "OK"
    except Exception as e:
        result["status"] = "ERREUR"
        result["error"]  = str(e)[:80]
        logger.error(f"{device['hostname']} — {e}")

    return result

def display_and_save(results: list[dict]):
    table = Table(
        title="État Infrastructure NETOPS-CORP",
        show_lines=True
    )
    table.add_column("Équipement",  style="bold cyan")
    table.add_column("Site",        style="blue")
    table.add_column("Rôle")
    table.add_column("Statut",      justify="center")
    table.add_column("IF ↑/↓",      justify="center")
    table.add_column("BGP ↑/↓",     justify="center")

    for r in sorted(results, key=lambda x: (x["site"], x["hostname"])):
        status_str = "OK" if r["status"] == "OK" else f"{r['status']}"
        bgp = f"{r['bgp_peers_up']}/{r['bgp_peers_down']}" \
              if r["bgp_peers_up"] + r["bgp_peers_down"] > 0 else "N/A"
        table.add_row(
            r["hostname"], r["site"], r["role"], status_str,
            f"{r['interfaces_up']}/{r['interfaces_down']}",
            bgp
        )

    console.print(table)

    # Sauvegarde JSON
    Path("reports").mkdir(exist_ok=True)
    fname = f"reports/state_{datetime.now().strftime('%Y%m%d_%H%M')}.json"
    with open(fname, "w") as f:
        json.dump(results, f, indent=2)
    console.print(f"\nRapport : {fname}")

if __name__ == "__main__":
    console.print("[bold]Collecte état NETOPS-CORP...[/bold]\n")
    hosts = load_hosts_from_inventory("inventories/production/hosts.yml")
    console.print(f"   {len(hosts)} équipements dans l'inventaire\n")

    results = []
    with Progress() as progress:
        task = progress.add_task(
            "Interrogation...", total=len(hosts)
        )
        with ThreadPoolExecutor(max_workers=10) as executor:
            futures = {
                executor.submit(collect_one_device, h): h
                for h in hosts
            }
            for future in as_completed(futures):
                results.append(future.result())
                progress.advance(task)

    display_and_save(results)

